# ---- Supabase (Driveway Advocate project: driveway-advocate / vwnnhmxjjxfoctylisfn) ----
# Public values — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://vwnnhmxjjxfoctylisfn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-publishable-key

# Server-only — NEVER expose to the browser. Used by server actions to write
# intake submissions and upload quote files. Get it from:
# Supabase Dashboard -> Project Settings -> API -> service_role secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# ---- Internal review console (/console) ----
# Shared password the team types to access the review console. The console is
# LOCKED until this is set. Use a long random value.
CONSOLE_PASSWORD=set-a-strong-shared-password
